# Root-level local development variables (non-secret placeholders only)
# Copy into client/.env (Vite) and api/.env (Fastify) as needed — each tool reads env from its package directory.
# Use explicit API URL in the client via VITE_API_BASE_URL, or use a local dev proxy once configured.

VITE_API_BASE_URL=http://localhost:3000
PORT=3000
DATABASE_PATH=./data/todos.db
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development
