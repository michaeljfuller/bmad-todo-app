# Root ignore rules for this repo.
# Keep lockfiles and .env.example tracked.
# Ignore local-only dependencies, build/test outputs, secrets, DB files,
# Playwright artifacts/cache, and OS/editor clutter.

# Dependencies
node_modules/

# Build and bundler output
dist/
build/
.vite/
*.local

# Environment and secrets (example file stays committed)
.env
.env.local
.env.*.local

# SQLite and local database files
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite*-journal
*.sqlite-shm
*.sqlite-wal
*-shm
*-wal
data/
tmp/
.tmp/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Test and coverage artifacts
coverage/
.nyc_output/
.vitest/

# Playwright artifacts and local browser caches
playwright-report/
test-results/
blob-report/
.cache/ms-playwright/
.cache/playwright/

# OS and editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
